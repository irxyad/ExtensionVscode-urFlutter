// See https://go.microsoft.com/fwlink/?LinkId=733558
// for the documentation about the tasks.json format
{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Development",
			"type": "shell",
			"command": "npm run dev",
			"isBackground": true,
			"problemMatcher": {
				"pattern": [
					{
						"regexp": "^(.*):(\\d+):(\\d+):\\s+(.*)$",
						"file": 1,
						"line": 2,
						"column": 3,
						"message": 4
					}
				],
				"background": {
					"activeOnStart": true,
					"beginsPattern": "^\\[watch\\]",
					"endsPattern": "\\[watch\\] build finished, watching for changes\\.\\.\\."
				}
			}
		}
	]
}
